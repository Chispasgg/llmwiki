# === API (.env in api/) ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/wiki
STAGE=dev
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
MCP_URL=http://localhost:8080/mcp

# Auth (cookie sessions)
SESSION_EXPIRE_SECONDS=86400
COOKIE_SECURE=false          # true en producción (requiere HTTPS)

# Voyage AI (embeddings) — opcional
VOYAGE_API_KEY=
TURBOPUFFER_API_KEY=

# Conversión de documentos — opcional
CONVERTER_URL=
CONVERTER_SECRET=

# Observabilidad — opcional
LOGFIRE_TOKEN=
SENTRY_DSN=

# === Web (.env.local in web/) ===
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_MODE=local  # o hosted

# ── Acceso en red local (LAN) ──────────────────────────────────────────────
# Por defecto el CLI y el lanzador auto-detectan la IP LAN.
# Puedes forzarlas aquí o en config/llmwiki-launcher.conf:
# APP_URL=http://192.168.1.10:1504
# API_URL=http://192.168.1.10:1503
# NEXT_PUBLIC_API_URL=http://192.168.1.10:1503
